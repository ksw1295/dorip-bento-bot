{
  "manifest_version": 3,
  "name": "도립대 밥봇 Pro v2.1",
  "version": "2.1",
  "permissions": ["storage", "alarms", "tabs"],
  "host_permissions": ["https://form.naver.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["https://form.naver.com/*"],
    "js": ["content.js"]
  }],
  "action": {
    "default_popup": "popup.html"
  }
}